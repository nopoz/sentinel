---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	plan(plan)
	act(act)
	reflect(reflect)
	approval(approval)
	execute(execute)
	finish(finish)
	__end__([<p>__end__</p>]):::last
	__start__ --> plan;
	act --> reflect;
	approval -.-> execute;
	approval -.-> finish;
	execute --> finish;
	plan --> act;
	reflect -.-> act;
	reflect -.-> approval;
	reflect -.-> finish;
	finish --> __end__;
	classDef default fill:#eef2ff,color:#111827,stroke:#818cf8,stroke-width:1px,line-height:1.2
	classDef first fill:#bbf7d0,color:#064e3b,stroke:#16a34a,stroke-width:1px
	classDef last fill:#ddd6fe,color:#3b0764,stroke:#7c3aed,stroke-width:1px
